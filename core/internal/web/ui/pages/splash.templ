package pages

import "github.com/kendricklawton/project-platform/core/internal/web/ui/components"

templ SplashPage(status string, userName string) {
	@components.Layout("Project Platform | The complied language cloud", userName) {
		@SplashContent(status, userName)
	}
}


templ SplashContent(status string, userName string) {
	<div class="flex flex-col gap-24 py-12 relative">
		// ── HERO ──────────────────────────────────────────────────────────────
		<section class="relative z-10 grid lg:grid-cols-2 gap-16 items-start">
			<div class="flex flex-col items-start">
				// Status badge
				<div class="inline-flex items-center gap-2 px-3 py-1.5 mb-10 border border-zinc-300 dark:border-atom-border bg-zinc-100 dark:bg-atom-surface text-[10px] font-bold tracking-widest text-zinc-500 dark:text-atom-muted uppercase">
					<div class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse shadow-[0_0_8px_rgba(34,197,94,0.6)]"></div>
					SYS_STATUS: ONLINE
					<span class="border-l border-zinc-300 dark:border-atom-border pl-2 ml-1">v0.1.0-alpha</span>
				</div>
				// Headline
				<h1 class="text-4xl sm:text-5xl lg:text-6xl font-black tracking-tighter mb-6 leading-[0.9]">
					<span class="text-zinc-900 dark:text-white">COMPILE.</span>
					<span class="text-zinc-400 dark:text-atom-muted block">SHIP.</span>
					<span class="text-zinc-200 dark:text-atom-border block">RUN.</span>
				</h1>
				// Subtext
				<p class="text-sm text-zinc-500 dark:text-atom-muted mb-8 max-w-md leading-loose font-mono border-l-2 border-zinc-300 dark:border-atom-border pl-4">
					No SDK. No agent. Zero vendor imports.
					<br/>
					Write standard Go or Rust — just listen on a port.
					<br/>
					We compile, deploy, and run your binary.
				</p>
				// Language pills
				<div class="flex items-center gap-2 mb-10">
					<span class="text-[10px] font-mono text-zinc-400 dark:text-atom-muted uppercase tracking-widest mr-1">Lang:</span>
					<span class="inline-flex items-center gap-1.5 px-2.5 py-1 border border-blue-300 dark:border-atom-blue/40 bg-blue-50 dark:bg-atom-blue/10 text-[10px] font-bold font-mono uppercase tracking-widest text-blue-700 dark:text-atom-blue">
						<span class="w-1 h-1 rounded-full bg-blue-500 dark:bg-atom-blue inline-block"></span>
						Go
					</span>
					<span class="inline-flex items-center gap-1.5 px-2.5 py-1 border border-amber-300 dark:border-atom-yellow/40 bg-amber-50 dark:bg-atom-yellow/10 text-[10px] font-bold font-mono uppercase tracking-widest text-amber-700 dark:text-atom-yellow">
						<span class="w-1 h-1 rounded-full bg-amber-500 dark:bg-atom-yellow inline-block"></span>
						Rust
					</span>
					<span class="inline-flex items-center gap-1.5 px-2.5 py-1 border border-zinc-200 dark:border-atom-border/50 text-[10px] font-bold font-mono uppercase tracking-widest text-zinc-400 dark:text-atom-muted opacity-60">
						Zig
						<span class="text-zinc-400 dark:text-atom-muted">→</span>
					</span>
				</div>
				// CTAs
				<div class="flex flex-col sm:flex-row gap-3">
					if userName != "" {
						<a href="/dashboard" class="inline-flex items-center justify-center gap-2 px-8 py-3 border border-zinc-900 dark:border-white bg-zinc-900 dark:bg-white text-white dark:text-black font-bold text-xs tracking-widest uppercase hover:opacity-80 transition-opacity">
							<i data-lucide="layout-dashboard" width="14" height="14"></i>
							Enter Workspace
						</a>
					} else {
						<a href="/auth/login" class="inline-flex items-center justify-center gap-2 px-8 py-3 border border-zinc-900 dark:border-white bg-zinc-900 dark:bg-white text-white dark:text-black font-bold text-xs tracking-widest uppercase hover:opacity-80 transition-opacity">
							<i data-lucide="log-in" width="14" height="14"></i>
							Get Started
						</a>
					}
					<a href="https://github.com/kendricklawton/project-platform" target="_blank" class="inline-flex items-center justify-center gap-2 px-8 py-3 border border-zinc-300 dark:border-atom-border text-zinc-600 dark:text-atom-muted font-bold text-xs tracking-widest uppercase hover:border-zinc-900 dark:hover:border-atom-fg hover:text-zinc-900 dark:hover:text-atom-fg transition-colors">
						<i data-lucide="github" width="14" height="14"></i>
						View Source
					</a>
				</div>
			</div>
			// Tabbed code editor (desktop only)
			<div class="hidden lg:block" x-data="{ lang: 'go' }">
				<div class="border border-zinc-300 dark:border-atom-border bg-white dark:bg-atom-surface shadow-2xl">
					// Window chrome with language tabs
					<div class="flex items-center px-4 border-b border-zinc-200 dark:border-atom-border bg-zinc-100 dark:bg-atom-bg gap-4">
						<div class="flex items-center gap-1.5 shrink-0 py-2.5">
							<div class="w-2.5 h-2.5 rounded-full bg-red-400 dark:bg-atom-red opacity-80"></div>
							<div class="w-2.5 h-2.5 rounded-full bg-yellow-400 dark:bg-atom-yellow opacity-80"></div>
							<div class="w-2.5 h-2.5 rounded-full bg-green-400 dark:bg-atom-green opacity-80"></div>
						</div>
						<div class="flex gap-0">
							<button
								@click="lang = 'go'"
								:class="lang === 'go' ? 'border-b-2 border-blue-500 dark:border-atom-blue text-zinc-900 dark:text-white px-3 py-2.5 text-[10px] font-mono uppercase tracking-widest transition-colors cursor-pointer focus:outline-none' : 'border-b-2 border-transparent text-zinc-400 dark:text-atom-muted hover:text-zinc-700 dark:hover:text-zinc-300 px-3 py-2.5 text-[10px] font-mono uppercase tracking-widest transition-colors cursor-pointer focus:outline-none'"
							>
								main.go
							</button>
							<button
								@click="lang = 'rust'"
								:class="lang === 'rust' ? 'border-b-2 border-amber-500 dark:border-atom-yellow text-zinc-900 dark:text-white px-3 py-2.5 text-[10px] font-mono uppercase tracking-widest transition-colors cursor-pointer focus:outline-none' : 'border-b-2 border-transparent text-zinc-400 dark:text-atom-muted hover:text-zinc-700 dark:hover:text-zinc-300 px-3 py-2.5 text-[10px] font-mono uppercase tracking-widest transition-colors cursor-pointer focus:outline-none'"
							>
								main.rs
							</button>
						</div>
					</div>
					// Go code — stdlib only, no SDK
					<div x-show="lang === 'go'" class="p-6 text-xs font-mono leading-loose text-zinc-800 dark:text-atom-fg select-text">
						<div><span class="text-purple-600 dark:text-atom-purple">package</span> main</div>
						<div class="h-3"></div>
						<div><span class="text-purple-600 dark:text-atom-purple">import</span> (</div>
						<div class="pl-4"><span class="text-green-600 dark:text-atom-green">"net/http"</span></div>
						<div class="pl-4"><span class="text-green-600 dark:text-atom-green">"os"</span></div>
						<div>)</div>
						<div class="h-3"></div>
						<div class="text-zinc-400 dark:text-atom-muted">{ "// No SDK. Platform tunes GOMEMLIMIT, GOGC, GOMAXPROCS." }</div>
						<div><span class="text-purple-600 dark:text-atom-purple">func</span> <span class="text-blue-600 dark:text-atom-blue">main</span>() { "{" }</div>
						<div class="pl-4"><span class="text-cyan-600 dark:text-atom-cyan">port</span> := os.<span class="text-blue-600 dark:text-atom-blue">Getenv</span>(<span class="text-green-600 dark:text-atom-green">"PORT"</span>)</div>
						<div class="pl-4">http.<span class="text-blue-600 dark:text-atom-blue">HandleFunc</span>(<span class="text-green-600 dark:text-atom-green">"/healthz"</span>, healthz)</div>
						<div class="pl-4">http.<span class="text-blue-600 dark:text-atom-blue">ListenAndServe</span>(<span class="text-green-600 dark:text-atom-green">":"</span>+<span class="text-cyan-600 dark:text-atom-cyan">port</span>, <span class="text-yellow-600 dark:text-atom-yellow">nil</span>)</div>
						<div>{ "}" }</div>
					</div>
					// Rust code — axum + tokio only, no platform SDK
					<div x-show="lang === 'rust'" style="display: none;" class="p-6 text-xs font-mono leading-loose text-zinc-800 dark:text-atom-fg select-text">
						<div><span class="text-purple-600 dark:text-atom-purple">use</span> axum::<span class="text-yellow-600 dark:text-atom-yellow">{ "{" }Router, routing::get{ "}" }</span>;</div>
						<div><span class="text-purple-600 dark:text-atom-purple">use</span> tokio::net::<span class="text-yellow-600 dark:text-atom-yellow">TcpListener</span>;</div>
						<div class="h-3"></div>
						<div class="text-zinc-400 dark:text-atom-muted">{ "// No SDK. No macro. Standard Rust + axum." }</div>
						<div><span class="text-red-500 dark:text-atom-red">#[tokio::main]</span></div>
						<div><span class="text-purple-600 dark:text-atom-purple">async fn</span> <span class="text-blue-600 dark:text-atom-blue">main</span>() { "{" }</div>
						<div class="pl-4"><span class="text-purple-600 dark:text-atom-purple">let</span> app = Router::<span class="text-blue-600 dark:text-atom-blue">new</span>()</div>
						<div class="pl-8">.<span class="text-blue-600 dark:text-atom-blue">route</span>(<span class="text-green-600 dark:text-atom-green">"/healthz"</span>, <span class="text-blue-600 dark:text-atom-blue">get</span>(|| <span class="text-purple-600 dark:text-atom-purple">async</span> { "{ " }<span class="text-green-600 dark:text-atom-green">"ok"</span>{ " }" }))</div>
						<div class="pl-8">.<span class="text-blue-600 dark:text-atom-blue">route</span>(<span class="text-green-600 dark:text-atom-green">"/"</span>, <span class="text-blue-600 dark:text-atom-blue">get</span>(handler));</div>
						<div class="pl-4"><span class="text-purple-600 dark:text-atom-purple">let</span> port = std::env::<span class="text-blue-600 dark:text-atom-blue">var</span>(<span class="text-green-600 dark:text-atom-green">"PORT"</span>).<span class="text-cyan-600 dark:text-atom-cyan">unwrap_or</span>(<span class="text-green-600 dark:text-atom-green">"3000"</span>.<span class="text-cyan-600 dark:text-atom-cyan">into</span>());</div>
						<div class="pl-4"><span class="text-purple-600 dark:text-atom-purple">let</span> l = TcpListener::<span class="text-blue-600 dark:text-atom-blue">bind</span>(<span class="text-blue-600 dark:text-atom-blue">format!</span>(<span class="text-green-600 dark:text-atom-green">"0.0.0.0:{ "{" }port{ "}" }"</span>)).<span class="text-cyan-600 dark:text-atom-cyan">await</span>.<span class="text-cyan-600 dark:text-atom-cyan">unwrap</span>();</div>
						<div class="pl-4">axum::<span class="text-blue-600 dark:text-atom-blue">serve</span>(l, app).<span class="text-cyan-600 dark:text-atom-cyan">await</span>.<span class="text-cyan-600 dark:text-atom-cyan">unwrap</span>()</div>
						<div>{ "}" }</div>
					</div>
				</div>
			</div>
		</section>
		// ── STATS BAR ─────────────────────────────────────────────────────────
		<section class="relative z-10">
			<div class="border border-zinc-200 dark:border-atom-border bg-white dark:bg-atom-bg grid grid-cols-2 md:grid-cols-4 divide-x divide-y md:divide-y-0 divide-zinc-200 dark:divide-atom-border">
				<div class="flex flex-col gap-1.5 px-8 py-7">
					<span class="text-3xl font-black text-zinc-900 dark:text-white tracking-tight">sub-ms</span>
					<span class="text-[10px] font-mono text-zinc-400 dark:text-atom-muted uppercase tracking-widest">Cold Start</span>
				</div>
				<div class="flex flex-col gap-1.5 px-8 py-7">
					<span class="text-3xl font-black text-zinc-900 dark:text-white tracking-tight">zero</span>
					<span class="text-[10px] font-mono text-zinc-400 dark:text-atom-muted uppercase tracking-widest">SDK Required</span>
				</div>
				<div class="flex flex-col gap-1.5 px-8 py-7">
					<span class="text-2xl font-black text-zinc-900 dark:text-white tracking-tight">Go · Rust</span>
					<span class="text-[10px] font-mono text-zinc-400 dark:text-atom-muted uppercase tracking-widest">Languages</span>
				</div>
				<div class="flex flex-col gap-1.5 px-8 py-7">
					<span class="text-3xl font-black text-zinc-300 dark:text-atom-border tracking-tight">Zig</span>
					<span class="text-[10px] font-mono text-zinc-400 dark:text-atom-muted uppercase tracking-widest">Coming Next</span>
				</div>
			</div>
		</section>
		// ── FEATURES ──────────────────────────────────────────────────────────
		<section class="relative z-10">
			<div class="mb-10">
				<span class="text-[10px] font-mono text-zinc-400 dark:text-atom-muted uppercase tracking-widest">{ "// Zero-SDK" }</span>
				<h2 class="text-xl font-black text-zinc-900 dark:text-white uppercase tracking-widest mt-1">Bring Your Own Binary.</h2>
			</div>
			<div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-zinc-200 dark:bg-atom-border border border-zinc-200 dark:border-atom-border">
				@splashFeatureCard("01", "zap", "Instant Wake", "No interpreter, no JVM warmup. Static binaries wake from sleep at the speed of exec() — sub-millisecond, every time.", "both")
				@splashFeatureCard("02", "activity", "Goroutine Autoscale", "M:N scheduled goroutines with native backpressure tracking. Scale from one request to millions without thread-pool overhead or per-goroutine stack limits.", "go")
				@splashFeatureCard("03", "cpu", "No GC. No Runtime.", "Rust has no garbage collector. No stop-the-world pauses. No hidden allocator on your hot path. Memory is released the instant ownership ends — determined at compile time.", "rust")
				@splashFeatureCard("04", "sliders", "GC-Tuned Runtime", "Go's GC is real and we tune it. GOMEMLIMIT caps memory under pressure. GOGC controls collection frequency. pprof streams live heap and CPU profiles from the dashboard.", "go")
				@splashFeatureCard("05", "shield", "Ownership & Safety", "Rust's borrow checker ships as a platform feature. Data races, use-after-free, and null derefs are caught at compile time — not discovered in production.", "rust")
				@splashFeatureCard("06", "box", "Bring Your Own Binary", "No proprietary SDK. No platform imports. Write any standard Go or Rust binary — just serve on a port and respond to a health endpoint. The platform wraps your process, not your code.", "both")
				@splashFeatureCard("07", "rotate-ccw", "Atomic Rollbacks", "Health checks gate every deploy. A panic, segfault, or failed probe instantly reverts to the last known-good revision — no manual intervention.", "both")
				@splashFeatureCard("08", "git-pull-request", "Preview Environments", "Every pull request gets a live, isolated URL before it merges to main. Test in production topology without touching production.", "both")
				@splashFeatureCard("09", "lock", "Encrypted Secrets", "Zero .env files. Secrets are encrypted at rest and injected as environment variables at runtime — never baked into your binary.", "both")
				@splashFeatureCard("10", "layers", "Multi-arch Builds", "Compile for amd64 and arm64 in a single push. GOARCH=arm64 CGO_ENABLED=0 for Go. aarch64-unknown-linux-musl for Rust. Run on whatever hardware costs less.", "both")
				@splashFeatureCard("11", "zap-off", "Race Detector Builds", "Go's -race flag instruments every memory access at runtime. Preview environments automatically run race-enabled builds so data races surface before code reaches main.", "go")
				@splashFeatureCard("12", "scan-search", "Dependency Auditing", "govulncheck for Go. cargo audit for Rust. Every push scans your entire statically-linked dependency tree against the OSV database — no CVEs slip through.", "both")
			</div>
		</section>
		// ── CLI ───────────────────────────────────────────────────────────────
		<section class="relative z-10">
			<div class="mb-10">
				<span class="text-[10px] font-mono text-zinc-400 dark:text-atom-muted uppercase tracking-widest">{ "// platform-cli" }</span>
				<h2 class="text-xl font-black text-zinc-900 dark:text-white uppercase tracking-widest mt-1">Ship From Your Terminal.</h2>
			</div>
			<div class="grid lg:grid-cols-2 gap-8">
				// Terminal session (left)
				<div class="border border-zinc-200 dark:border-atom-border bg-white dark:bg-atom-bg">
					<div class="flex items-center justify-between px-6 py-3 border-b border-zinc-200 dark:border-atom-border bg-zinc-50 dark:bg-atom-surface">
						<div class="flex items-center gap-1.5">
							<div class="w-2.5 h-2.5 rounded-full bg-red-400 dark:bg-atom-red opacity-80"></div>
							<div class="w-2.5 h-2.5 rounded-full bg-yellow-400 dark:bg-atom-yellow opacity-80"></div>
							<div class="w-2.5 h-2.5 rounded-full bg-green-400 dark:bg-atom-green opacity-80"></div>
						</div>
						<span class="text-[10px] font-mono text-zinc-500 dark:text-atom-muted uppercase tracking-widest">Terminal — platform CLI</span>
						<span class="text-[10px] font-mono text-zinc-400 dark:text-atom-muted">v0.1.0</span>
					</div>
					<div class="p-6 font-mono text-xs leading-loose overflow-x-auto">
						@splashCLILine("cmd", "plat init my-api")
						@splashCLILine("success", "Created project: my-api")
						@splashCLILine("success", "Generated plat.toml")
						@splashCLILine("gap", "")
						@splashCLILine("cmd", "plat deploy my-api")
						@splashCLILine("muted", "Building Go binary (linux/amd64)...")
						@splashCLILine("success", "Binary: 3.1MB (stripped + static)")
						@splashCLILine("success", "Revision r42 live → my-api.platform.dev")
						@splashCLILine("gap", "")
						@splashCLILine("cmd", "plat logs my-api --tail")
						@splashCLILine("log", "[INFO] Service started on :8080")
						@splashCLILine("log", "[INFO] GET /healthz 200 0.1ms")
						@splashCLILine("gap", "")
						@splashCLILine("cmd", "plat rollback my-api")
						@splashCLILine("success", "Rolled back to revision r41")
					</div>
				</div>
				// Command reference (right)
				<div class="flex flex-col gap-px bg-zinc-200 dark:bg-atom-border border border-zinc-200 dark:border-atom-border">
					@splashCLICmd("init", "[project]", "Scaffold a new project and generate plat.toml")
					@splashCLICmd("deploy", "[project]", "Build, containerize, and deploy to production")
					@splashCLICmd("logs", "[project] [--tail]", "Stream live logs from running services")
					@splashCLICmd("status", "[project]", "Show service health, uptime, and replica count")
					@splashCLICmd("revisions", "[project]", "List all deployments with timestamps and IDs")
					@splashCLICmd("rollback", "[project]", "Instantly revert to the last healthy revision")
					@splashCLICmd("secret", "set KEY=value", "Encrypt and inject a secret at runtime")
					@splashCLICmd("version", "", "Print CLI version and connected API endpoint")
				</div>
			</div>
		</section>
		// ── AI AGENTS ─────────────────────────────────────────────────────────
		<section class="relative z-10">
			<div class="mb-10">
				<span class="text-[10px] font-mono text-zinc-400 dark:text-atom-muted uppercase tracking-widest">{ "// ai-agents" }</span>
				<h2 class="text-xl font-black text-zinc-900 dark:text-white uppercase tracking-widest mt-1">Let Your Agent Deploy.</h2>
			</div>
			<div class="grid lg:grid-cols-2 gap-8 items-start">
				// Copy (left)
				<div class="flex flex-col gap-6">
					<p class="text-sm text-zinc-500 dark:text-atom-muted font-mono leading-loose border-l-2 border-zinc-300 dark:border-atom-border pl-4">
						The platform exposes a structured API that AI assistants can call directly.
						Claude, Gemini, or any agent with tool-use support can authenticate, deploy services,
						manage secrets, and stream logs — without you touching a terminal.
					</p>
					<div class="grid sm:grid-cols-2 gap-px bg-zinc-200 dark:bg-atom-border border border-zinc-200 dark:border-atom-border">
						<div class="bg-white dark:bg-atom-bg p-5 flex flex-col gap-2">
							<div class="flex items-center gap-2">
								<i data-lucide="bot" width="14" height="14" class="text-zinc-400 dark:text-atom-muted shrink-0"></i>
								<span class="text-[10px] font-bold text-zinc-900 dark:text-white uppercase tracking-widest">Deploy</span>
							</div>
							<p class="text-[10px] font-mono text-zinc-500 dark:text-atom-muted leading-loose">Agent pushes a new revision from a repo URL or a local build artifact.</p>
						</div>
						<div class="bg-white dark:bg-atom-bg p-5 flex flex-col gap-2">
							<div class="flex items-center gap-2">
								<i data-lucide="scroll-text" width="14" height="14" class="text-zinc-400 dark:text-atom-muted shrink-0"></i>
								<span class="text-[10px] font-bold text-zinc-900 dark:text-white uppercase tracking-widest">Stream Logs</span>
							</div>
							<p class="text-[10px] font-mono text-zinc-500 dark:text-atom-muted leading-loose">Agent tails live logs to surface errors, latency spikes, and panics in context.</p>
						</div>
						<div class="bg-white dark:bg-atom-bg p-5 flex flex-col gap-2">
							<div class="flex items-center gap-2">
								<i data-lucide="rotate-ccw" width="14" height="14" class="text-zinc-400 dark:text-atom-muted shrink-0"></i>
								<span class="text-[10px] font-bold text-zinc-900 dark:text-white uppercase tracking-widest">Rollback</span>
							</div>
							<p class="text-[10px] font-mono text-zinc-500 dark:text-atom-muted leading-loose">Agent detects a failing health check and reverts to the last known-good revision.</p>
						</div>
						<div class="bg-white dark:bg-atom-bg p-5 flex flex-col gap-2">
							<div class="flex items-center gap-2">
								<i data-lucide="lock" width="14" height="14" class="text-zinc-400 dark:text-atom-muted shrink-0"></i>
								<span class="text-[10px] font-bold text-zinc-900 dark:text-white uppercase tracking-widest">Secrets</span>
							</div>
							<p class="text-[10px] font-mono text-zinc-500 dark:text-atom-muted leading-loose">Agent rotates and injects encrypted secrets without ever reading the plaintext value.</p>
						</div>
					</div>
					<div class="flex items-center gap-3 pt-2">
						<span class="text-[9px] font-bold font-mono px-2 py-1 border border-zinc-300 dark:border-atom-border text-zinc-500 dark:text-atom-muted uppercase tracking-widest">Free</span>
						<span class="text-[9px] font-bold font-mono px-2 py-1 border border-zinc-300 dark:border-atom-border text-zinc-500 dark:text-atom-muted uppercase tracking-widest">Pro</span>
						<span class="text-[10px] font-mono text-zinc-400 dark:text-atom-muted">Available on all plans.</span>
					</div>
				</div>
				// Agent terminal session (right)
				<div class="border border-zinc-200 dark:border-atom-border bg-white dark:bg-atom-bg">
					<div class="flex items-center justify-between px-6 py-3 border-b border-zinc-200 dark:border-atom-border bg-zinc-50 dark:bg-atom-surface">
						<div class="flex items-center gap-1.5">
							<div class="w-2.5 h-2.5 rounded-full bg-red-400 dark:bg-atom-red opacity-80"></div>
							<div class="w-2.5 h-2.5 rounded-full bg-yellow-400 dark:bg-atom-yellow opacity-80"></div>
							<div class="w-2.5 h-2.5 rounded-full bg-green-400 dark:bg-atom-green opacity-80"></div>
						</div>
						<span class="text-[10px] font-mono text-zinc-500 dark:text-atom-muted uppercase tracking-widest">Agent Session — Claude</span>
						<span class="inline-flex items-center gap-1.5 text-[10px] font-mono text-green-600 dark:text-atom-green">
							<span class="w-1.5 h-1.5 rounded-full bg-green-500 dark:bg-atom-green animate-pulse inline-block"></span>
							LIVE
						</span>
					</div>
					<div class="p-6 font-mono text-xs leading-loose overflow-x-auto">
						<div class="flex gap-2 text-zinc-400 dark:text-atom-muted mb-3">
							<span class="shrink-0">›</span>
							<span>Deploy the latest revision of my-api to production.</span>
						</div>
						@splashCLILine("muted", "Authenticating with platform API...")
						@splashCLILine("success", "Token verified. Project: my-api")
						@splashCLILine("gap", "")
						@splashCLILine("muted", "Fetching latest commit from main...")
						@splashCLILine("muted", "Queuing build (Go · linux/amd64)...")
						@splashCLILine("success", "Binary: 3.1MB — build passed in 18s")
						@splashCLILine("gap", "")
						@splashCLILine("muted", "Running health check on new revision...")
						@splashCLILine("success", "Revision r44 live → my-api.platform.dev")
						@splashCLILine("gap", "")
						<div class="flex gap-2 text-zinc-400 dark:text-atom-muted mt-3">
							<span class="shrink-0">›</span>
							<span>Done. my-api is deployed and healthy. <span class="text-green-600 dark:text-atom-green">No action needed.</span></span>
						</div>
					</div>
				</div>
			</div>
		</section>
		// ── PIPELINE LOG ──────────────────────────────────────────────────────
		<section class="relative z-10">
			<div class="border border-zinc-200 dark:border-atom-border bg-white dark:bg-atom-bg">
				// Terminal chrome
				<div class="flex items-center justify-between px-6 py-3 border-b border-zinc-200 dark:border-atom-border bg-zinc-50 dark:bg-atom-surface">
					<div class="flex items-center gap-1.5">
						<div class="w-2.5 h-2.5 rounded-full bg-red-400 dark:bg-atom-red opacity-80"></div>
						<div class="w-2.5 h-2.5 rounded-full bg-yellow-400 dark:bg-atom-yellow opacity-80"></div>
						<div class="w-2.5 h-2.5 rounded-full bg-green-400 dark:bg-atom-green opacity-80"></div>
					</div>
					<span class="text-[10px] font-mono text-zinc-500 dark:text-atom-muted uppercase tracking-widest">Execution Pipeline — Rust Build</span>
					<span class="inline-flex items-center gap-1.5 text-[10px] font-mono text-green-600 dark:text-atom-green">
						<span class="w-1.5 h-1.5 rounded-full bg-green-500 dark:bg-atom-green animate-pulse inline-block"></span>
						LIVE
					</span>
				</div>
				// Log lines
				<div class="p-6 font-mono text-xs leading-loose overflow-x-auto">
					@splashLogLine("00:00.000", "INFO", "Webhook received. Detecting language...", "default")
					@splashLogLine("00:00.135", "INFO", "Detected Rust 1.76 (cargo).", "default")
					@splashLogLine("00:00.412", "INFO", "Fetching dependencies (cargo fetch)...", "default")
					@splashLogLine("00:02.100", "INFO", "Building release binary (x86_64-unknown-linux-musl)...", "default")
					@splashLogLine("00:02.101", "EXEC", "cargo build --release --target x86_64-unknown-linux-musl", "muted")
					@splashLogLine("00:18.450", "INFO", "Build complete. Binary size: 4.2MB. (stripped + LTO)", "default")
					@splashLogLine("00:18.500", "INFO", "Packaging into scratch container...", "default")
					@splashLogLine("00:20.100", "INFO", "Pushing artifact to registry...", "default")
					@splashLogLine("00:20.550", "SUCCESS", "DEPLOYMENT LIVE → https://api.platform.dev", "success")
				</div>
			</div>
		</section>
		// ── CTA BANNER ────────────────────────────────────────────────────────
		<section class="relative z-10 border border-zinc-200 dark:border-atom-border bg-zinc-900 dark:bg-atom-surface p-10 md:p-16 text-center overflow-hidden">
			<div class="absolute inset-0 opacity-[0.04] pointer-events-none" style="background-image: linear-gradient(white 1px, transparent 1px), linear-gradient(90deg, white 1px, transparent 1px); background-size: 24px 24px;"></div>
			<div class="relative z-10">
				<p class="text-[10px] font-mono text-zinc-500 dark:text-atom-muted uppercase tracking-widest mb-4">{ "// Ship it" }</p>
				<h2 class="text-3xl md:text-4xl font-black text-white tracking-tight mb-4">
					Write standard code.
					<br/>
					We handle the rest.
				</h2>
				<p class="text-sm text-zinc-400 dark:text-atom-muted mb-8 font-mono">No SDK. No agent. Your binary on our infrastructure.</p>
				<div class="flex flex-col sm:flex-row gap-3 justify-center">
					if userName != "" {
						<a href="/dashboard" class="inline-flex items-center justify-center gap-2 px-10 py-3.5 bg-white text-black font-bold text-xs tracking-widest uppercase hover:opacity-90 transition-opacity">
							<i data-lucide="layout-dashboard" width="14" height="14"></i>
							Enter Workspace
						</a>
					} else {
						<a href="/auth/login" class="inline-flex items-center justify-center gap-2 px-10 py-3.5 bg-white text-black font-bold text-xs tracking-widest uppercase hover:opacity-90 transition-opacity">
							<i data-lucide="log-in" width="14" height="14"></i>
							Get Started
						</a>
					}
					<a href="https://github.com/kendricklawton/project-platform" target="_blank" class="inline-flex items-center justify-center gap-2 px-10 py-3.5 border border-zinc-700 dark:border-atom-border text-zinc-300 dark:text-atom-muted font-bold text-xs tracking-widest uppercase hover:border-white hover:text-white transition-colors">
						<i data-lucide="github" width="14" height="14"></i>
						View Source
					</a>
				</div>
			</div>
		</section>
	</div>
}

templ splashFeatureCard(num string, icon string, title string, desc string, lang string) {
	<div class="group bg-white dark:bg-atom-bg hover:bg-zinc-50 dark:hover:bg-atom-surface transition-colors">
		<div class="p-6">
			<div class="flex items-center justify-between mb-4">
				<div class="flex items-center gap-3">
					<div class="text-zinc-400 dark:text-atom-muted group-hover:text-zinc-700 dark:group-hover:text-zinc-300 transition-colors">
						<i data-lucide={ icon } width="16" height="16"></i>
					</div>
					<span class="text-[10px] font-bold text-zinc-400 dark:text-atom-muted tracking-widest font-mono">{ num }_</span>
				</div>
				if lang == "go" {
					<span class="text-[9px] font-bold font-mono px-1.5 py-0.5 border border-blue-300 dark:border-atom-blue/40 text-blue-600 dark:text-atom-blue uppercase tracking-widest">Go</span>
				} else if lang == "rust" {
					<span class="text-[9px] font-bold font-mono px-1.5 py-0.5 border border-amber-300 dark:border-atom-yellow/40 text-amber-600 dark:text-atom-yellow uppercase tracking-widest">Rust</span>
				} else {
					<span class="text-[9px] font-bold font-mono px-1.5 py-0.5 border border-zinc-300 dark:border-zinc-600 text-zinc-400 dark:text-zinc-500 uppercase tracking-widest">Go · Rust</span>
				}
			</div>
			<h3 class="text-xs font-bold text-zinc-900 dark:text-white mb-2 uppercase tracking-widest group-hover:text-zinc-700 dark:group-hover:text-zinc-300 transition-colors">{ title }</h3>
			<p class="text-xs text-zinc-500 dark:text-atom-fg leading-relaxed">{ desc }</p>
		</div>
	</div>
}

templ splashLogLine(timestamp string, level string, message string, variant string) {
	<div class="flex gap-4 items-start">
		<span class="text-zinc-400 dark:text-atom-muted shrink-0">[{ timestamp }]</span>
		if variant == "success" {
			<span class="text-green-600 dark:text-atom-green font-bold">{ level } :: { message }</span>
		} else if variant == "muted" {
			<span class="text-zinc-400 dark:text-atom-muted">{ level } :: { message }</span>
		} else {
			<span><span class="text-zinc-900 dark:text-white font-bold">{ level }</span> :: { message }</span>
		}
	</div>
}

templ splashCLILine(lineType string, text string) {
	if lineType == "cmd" {
		<div class="flex gap-2">
			<span class="text-green-600 dark:text-atom-green select-none shrink-0">$</span>
			<span class="text-zinc-900 dark:text-white">{ text }</span>
		</div>
	} else if lineType == "success" {
		<div class="flex gap-2 pl-4">
			<span class="text-green-600 dark:text-atom-green shrink-0">✓</span>
			<span class="text-zinc-600 dark:text-atom-fg">{ text }</span>
		</div>
	} else if lineType == "muted" {
		<div class="pl-4 text-zinc-400 dark:text-atom-muted">{ text }</div>
	} else if lineType == "log" {
		<div class="pl-4 text-blue-600 dark:text-atom-cyan">{ text }</div>
	} else if lineType == "gap" {
		<div class="h-3"></div>
	}
}

templ splashCLICmd(cmd string, args string, desc string) {
	<div class="bg-white dark:bg-atom-bg p-4 flex flex-col gap-1.5 hover:bg-zinc-50 dark:hover:bg-atom-surface transition-colors">
		<div class="flex items-baseline gap-2 flex-wrap">
			<span class="text-[10px] font-bold font-mono text-zinc-900 dark:text-white">plat { cmd }</span>
			if args != "" {
				<span class="text-[10px] font-mono text-zinc-400 dark:text-atom-muted">{ args }</span>
			}
		</div>
		<p class="text-[10px] text-zinc-500 dark:text-atom-muted font-mono leading-relaxed">{ desc }</p>
	</div>
}
