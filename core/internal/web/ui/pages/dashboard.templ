// ── SERVICES ─────────────────────────────────────────────────────────────────

templ DashboardServicesPage(userName string, slug string) {
	@components.DashboardLayout("Services | Platform", userName, slug, "box", "Services") {
		@DashboardServicesContent()
	}
}

templ DashboardServicesContent() {
	<div data-page-title="Services" data-page-icon="box" class="flex flex-col h-full">
		<div class="px-6 lg:px-8 pt-6 lg:pt-8 pb-4 shrink-0"></div>
		<div class="px-6 lg:px-8 pb-6 lg:pb-8 flex flex-col min-h-0 flex-1">
			<div class="border border-zinc-200 dark:border-atom-border flex flex-col min-h-0 flex-1">
				<div class="flex items-center px-5 py-2 border-b border-zinc-200 dark:border-atom-border bg-zinc-100 dark:bg-atom-surface shrink-0">
					<span class="w-2 shrink-0"></span>
					<span class="ml-3 text-[10px] font-bold text-zinc-400 dark:text-atom-muted uppercase tracking-widest flex-1">Service</span>
					<span class="text-[10px] font-bold text-zinc-400 dark:text-atom-muted uppercase tracking-widest shrink-0 w-12">Type</span>
					<span class="text-[10px] font-bold text-zinc-400 dark:text-atom-muted uppercase tracking-widest shrink-0 w-16 text-right">Memory</span>
					<span class="text-[10px] font-bold text-zinc-400 dark:text-atom-muted uppercase tracking-widest shrink-0 w-20 text-right">State</span>
				</div>
				<div class="overflow-y-auto flex-1 min-h-0 scroll-container">
					for i := 0; i < 50; i++ {
						@dashServiceRow(
							mockNames[i%len(mockNames)],
							mockSvcStatuses[i%len(mockSvcStatuses)],
							mockSvcTypes[i%len(mockSvcTypes)],
							mockMemory[i%len(mockMemory)],
						)
					}
				</div>
			</div>
		</div>
	</div>
}

// ── DEPLOYMENTS ──────────────────────────────────────────────────────────────

templ DashboardDeploymentsPage(userName string, slug string) {
	@components.DashboardLayout("Deployments | Platform", userName, slug, "rocket", "Deployments") {
		@DashboardDeploymentsContent()
	}
}

templ DashboardDeploymentsContent() {
	<div data-page-title="Deployments" data-page-icon="rocket" class="flex flex-col h-full">
		// Actions bar
		<div class="px-6 lg:px-8 pt-6 lg:pt-8 pb-4 flex items-center justify-end shrink-0">
			<button class="flex items-center justify-center w-8 h-8 text-zinc-400 dark:text-atom-muted hover:text-zinc-900 dark:hover:text-atom-fg hover:bg-zinc-100 dark:hover:bg-atom-surface transition-colors">
				<i data-lucide="more-horizontal" width="16" height="16"></i>
			</button>
		</div>
		// Filters
		<div class="px-6 lg:px-8 pb-4 flex flex-wrap items-center gap-3 shrink-0">
			// Date range
			<button class="flex items-center gap-2 px-3 py-1.5 border border-zinc-200 dark:border-atom-border bg-white dark:bg-atom-bg hover:bg-zinc-50 dark:hover:bg-atom-surface transition-colors text-[11px] font-mono text-zinc-600 dark:text-atom-fg">
				<i data-lucide="calendar" width="12" height="12" class="text-zinc-400 dark:text-atom-muted"></i>
				Select Date Range
			</button>
			<div class="flex-1"></div>
			// Search authors
			<div class="flex items-center gap-2 px-3 py-1.5 border border-zinc-200 dark:border-atom-border bg-white dark:bg-atom-bg w-44">
				<i data-lucide="search" width="12" height="12" class="text-zinc-400 dark:text-atom-muted shrink-0"></i>
				<input
					type="text"
					placeholder="All Authors..."
					class="flex-1 bg-transparent text-[11px] font-mono text-zinc-900 dark:text-atom-fg placeholder-zinc-400 dark:placeholder-atom-muted outline-none min-w-0"
				/>
				<i data-lucide="chevron-down" width="10" height="10" class="text-zinc-400 dark:text-atom-muted shrink-0"></i>
			</div>
			// Environment filter
			<button class="flex items-center gap-2 px-3 py-1.5 border border-zinc-200 dark:border-atom-border bg-white dark:bg-atom-bg hover:bg-zinc-50 dark:hover:bg-atom-surface transition-colors text-[11px] font-mono text-zinc-600 dark:text-atom-fg">
				All Environments
				<i data-lucide="chevron-down" width="10" height="10" class="text-zinc-400 dark:text-atom-muted"></i>
			</button>
			// Status filter
			<button class="flex items-center gap-2 px-3 py-1.5 border border-zinc-200 dark:border-atom-border bg-white dark:bg-atom-bg hover:bg-zinc-50 dark:hover:bg-atom-surface transition-colors text-[11px] font-mono text-zinc-600 dark:text-atom-fg">
				<span class="flex items-center gap-0.5">
					<span class="w-1.5 h-1.5 rounded-full bg-emerald-500"></span>
					<span class="w-1.5 h-1.5 rounded-full bg-yellow-500"></span>
					<span class="w-1.5 h-1.5 rounded-full bg-red-500"></span>
				</span>
				Status
				<span class="text-zinc-400 dark:text-atom-muted">5/6</span>
				<i data-lucide="chevron-down" width="10" height="10" class="text-zinc-400 dark:text-atom-muted"></i>
			</button>
		</div>
		// Table
		<div class="px-6 lg:px-8 pb-6 lg:pb-8 flex flex-col min-h-0 flex-1">
			<div class="border border-zinc-200 dark:border-atom-border flex flex-col min-h-0 flex-1">
				<div class="flex items-center px-5 py-2 border-b border-zinc-200 dark:border-atom-border bg-zinc-100 dark:bg-atom-surface shrink-0">
					<span class="w-2 shrink-0"></span>
					<span class="ml-3 text-[10px] font-bold text-zinc-400 dark:text-atom-muted uppercase tracking-widest flex-1">Service</span>
					<span class="text-[10px] font-bold text-zinc-400 dark:text-atom-muted uppercase tracking-widest shrink-0 w-16">Commit</span>
					<span class="text-[10px] font-bold text-zinc-400 dark:text-atom-muted uppercase tracking-widest shrink-0 w-16 text-right">Time</span>
				</div>
				<div class="overflow-y-auto flex-1 min-h-0 scroll-container">
					for i := 0; i < 50; i++ {
						@dashDeploymentRow(
							mockNames[i%len(mockNames)],
							mockDeployStatuses[i%len(mockDeployStatuses)],
							fmt.Sprintf("%07x", 0xa1b2c30+i*0x11111),
							mockTimes[i%len(mockTimes)],
						)
					}
				</div>
			</div>
		</div>
	</div>
}

