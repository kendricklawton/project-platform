// ── SETTINGS ─────────────────────────────────────────────────────────────────

templ DashboardSettingsPage(userName string, slug string) {
	@components.DashboardLayout("Settings | Platform", userName, slug, "settings", "Settings") {
		@DashboardSettingsContent()
	}
}

templ DashboardSettingsContent() {
	<div data-page-title="Settings" data-page-icon="settings" class="p-6 lg:p-8 flex flex-col gap-6">
		// Team identity
		<div class="border border-zinc-200 dark:border-atom-border">
			<div class="px-5 py-3 border-b border-zinc-200 dark:border-atom-border bg-zinc-100 dark:bg-atom-surface">
				<span class="text-[10px] font-bold text-zinc-400 dark:text-atom-muted uppercase tracking-widest">Identity</span>
			</div>
			<div class="flex flex-col gap-0 divide-y divide-zinc-200 dark:divide-atom-border">
				<div class="flex items-center justify-between px-5 py-4">
					<div class="flex flex-col gap-0.5">
						<span class="text-xs font-bold text-zinc-900 dark:text-atom-fg uppercase tracking-widest">Team Name</span>
						<span class="text-[11px] text-zinc-500 dark:text-atom-muted">Display name for this team.</span>
					</div>
					<input
						type="text"
						placeholder="My Team"
						class="w-48 px-3 py-1.5 border border-zinc-200 dark:border-atom-border bg-white dark:bg-atom-bg text-xs font-mono text-zinc-900 dark:text-atom-fg placeholder-zinc-400 dark:placeholder-atom-muted outline-none focus:border-zinc-400 dark:focus:border-atom-fg"
					/>
				</div>
				<div class="flex items-center justify-between px-5 py-4">
					<div class="flex flex-col gap-0.5">
						<span class="text-xs font-bold text-zinc-900 dark:text-atom-fg uppercase tracking-widest">Slug</span>
						<span class="text-[11px] text-zinc-500 dark:text-atom-muted">Used in URLs. Cannot be changed.</span>
					</div>
					<span class="text-[11px] font-mono text-zinc-500 dark:text-atom-muted px-3 py-1.5 border border-zinc-200 dark:border-atom-border bg-zinc-100 dark:bg-atom-surface">team-slug</span>
				</div>
			</div>
		</div>
		// Members
		<div class="border border-zinc-200 dark:border-atom-border">
			<div class="px-5 py-3 border-b border-zinc-200 dark:border-atom-border bg-zinc-100 dark:bg-atom-surface flex items-center justify-between">
				<span class="text-[10px] font-bold text-zinc-400 dark:text-atom-muted uppercase tracking-widest">Members</span>
				<button class="px-3 py-1 bg-zinc-900 dark:bg-white text-[10px] font-bold text-white dark:text-zinc-900 uppercase tracking-widest hover:opacity-80 transition-opacity">
					Invite
				</button>
			</div>
			<div class="flex flex-col items-center justify-center py-12 gap-3">
				<i data-lucide="users" width="16" height="16" class="text-zinc-300 dark:text-atom-border"></i>
				<span class="text-[11px] font-mono text-zinc-500 dark:text-atom-muted">Member management coming soon.</span>
			</div>
		</div>
		// Danger zone
		<div class="border border-red-200 dark:border-atom-red/30">
			<div class="px-5 py-3 border-b border-red-200 dark:border-atom-red/30 bg-red-50 dark:bg-atom-red/5">
				<span class="text-[10px] font-bold text-red-500 dark:text-atom-red uppercase tracking-widest">Danger Zone</span>
			</div>
			<div class="flex items-center justify-between px-5 py-4">
				<div class="flex flex-col gap-0.5">
					<span class="text-xs font-bold text-zinc-900 dark:text-atom-fg uppercase tracking-widest">Delete Team</span>
					<span class="text-[11px] text-zinc-500 dark:text-atom-muted">Permanently deletes all projects, services, and deployments.</span>
				</div>
				<button
					class="px-4 py-1.5 border border-red-300 dark:border-atom-red/50 text-[10px] font-bold text-red-600 dark:text-atom-red uppercase tracking-widest hover:bg-red-50 dark:hover:bg-atom-red/10 transition-colors"
					disabled
				>
					Delete Team
				</button>
			</div>
		</div>
	</div>
}

// ── SHARED COMPONENTS ────────────────────────────────────────────────────────

templ dashPlaceholderPage(icon string, title string, desc string) {
	<div data-page-title={ title } data-page-icon={ icon } class="p-6 lg:p-8 flex flex-col gap-6">
		<div class="border border-zinc-200 dark:border-atom-border">
			<div class="flex flex-col items-center justify-center py-24 gap-4">
				<i data-lucide={ icon } width="20" height="20" class="text-zinc-300 dark:text-atom-border"></i>
				<p class="text-xs text-zinc-500 dark:text-atom-muted font-mono">{ desc }</p>
			</div>
		</div>
	</div>
}

templ dashUsageRow(label string, value string, limit string) {
	<div class="flex items-center justify-between px-5 py-3 border-b border-zinc-200 dark:border-atom-border last:border-b-0">
		<div class="flex items-center gap-3">
			<span class="w-2 h-2 rounded-full bg-zinc-300 dark:bg-atom-border shrink-0"></span>
			<span class="text-xs text-zinc-900 dark:text-atom-fg">{ label }</span>
		</div>
		<span class="text-xs font-mono text-zinc-500 dark:text-atom-muted">{ value + " / " + limit }</span>
	</div>
}

templ dashDeploymentRow(name string, status string, hash string, timeAgo string) {
	<div class="flex items-center px-5 py-3 border-b border-zinc-200 dark:border-atom-border last:border-b-0 hover:bg-zinc-50 dark:hover:bg-atom-surface">
		if status == "success" {
			<span class="w-2 h-2 rounded-full bg-emerald-500 shrink-0"></span>
		} else if status == "building" {
			<span class="w-2 h-2 rounded-full bg-yellow-500 shrink-0"></span>
		} else {
			<span class="w-2 h-2 rounded-full bg-red-500 shrink-0"></span>
		}
		<span class="ml-3 text-xs font-bold text-zinc-900 dark:text-atom-fg truncate">{ name }</span>
		<span class="ml-auto text-[10px] font-mono text-zinc-500 dark:text-atom-muted shrink-0 w-16">{ hash }</span>
		<span class="text-[10px] font-mono text-zinc-500 dark:text-atom-muted shrink-0 w-16 text-right">{ timeAgo }</span>
	</div>
}

templ dashServiceRow(name string, status string, svcType string, memory string) {
	<div class="flex items-center px-5 py-3 border-b border-zinc-200 dark:border-atom-border last:border-b-0 hover:bg-zinc-50 dark:hover:bg-atom-surface">
		if status == "running" {
			<span class="w-2 h-2 rounded-full bg-emerald-500 shrink-0"></span>
		} else if status == "deploying" {
			<span class="w-2 h-2 rounded-full bg-yellow-500 shrink-0"></span>
		} else {
			<span class="w-2 h-2 rounded-full bg-zinc-300 dark:bg-atom-border shrink-0"></span>
		}
		<span class="ml-3 text-xs font-bold text-zinc-900 dark:text-atom-fg truncate flex-1">{ name }</span>
		<span class="text-[10px] font-mono text-zinc-500 dark:text-atom-muted shrink-0 w-12">{ svcType }</span>
		<span class="text-[10px] font-mono text-zinc-500 dark:text-atom-muted shrink-0 w-16 text-right">{ memory }</span>
		if status == "running" {
			<span class="text-[10px] font-mono text-green-600 dark:text-atom-green uppercase tracking-widest shrink-0 w-20 text-right">Running</span>
		} else if status == "deploying" {
			<span class="text-[10px] font-mono text-yellow-600 dark:text-atom-yellow uppercase tracking-widest shrink-0 w-20 text-right">Deploying</span>
		} else {
			<span class="text-[10px] font-mono text-zinc-400 dark:text-atom-muted uppercase tracking-widest shrink-0 w-20 text-right">Stopped</span>
		}
	</div>
}
