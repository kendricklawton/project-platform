package pages

import (
	"fmt"

	"github.com/kendricklawton/project-platform/core/internal/web/ui/components"
)

var (
	mockNames          = []string{"api-gateway", "auth-service", "worker-pool", "metrics-agent", "edge-proxy", "cdn-origin", "webhook-relay", "task-scheduler", "log-aggregator", "config-server"}
	mockDeployStatuses = []string{"success", "success", "success", "success", "success", "success", "building", "building", "failed", "success"}
	mockTimes          = []string{"2m ago", "8m ago", "15m ago", "32m ago", "1h ago", "2h ago", "4h ago", "8h ago", "12h ago", "1d ago"}
	mockSvcStatuses    = []string{"running", "running", "running", "running", "running", "running", "running", "stopped", "deploying", "running"}
	mockSvcTypes       = []string{"Go", "Rust", "Go", "Zig", "Rust", "Go", "Go", "Rust", "Go", "Zig"}
	mockMemory         = []string{"24 MB", "12 MB", "48 MB", "8 MB", "32 MB", "16 MB", "64 MB", "0 MB", "28 MB", "18 MB"}
)

// ── OVERVIEW ─────────────────────────────────────────────────────────────────

templ DashboardPage(userName string, slug string) {
	@components.DashboardLayout("Projects | Platform", userName, slug, "layout-grid", "Projects") {
		@DashboardContent(userName, slug)
	}
}

templ DashboardContent(userName string, slug string) {
	<div data-page-title="Projects" data-page-icon="layout-grid" class="p-6 lg:p-8 flex flex-col gap-8">
		// Action bar
		<div class="flex justify-end">
			<a
				href={ templ.SafeURL("/"+slug+"/new") }
				class="flex items-center gap-2 px-4 py-2 bg-zinc-900 dark:bg-white text-[10px] font-bold text-white dark:text-zinc-900 uppercase tracking-widest hover:opacity-80 transition-opacity"
			>
				<i data-lucide="plus" width="12" height="12"></i>
				New Project
			</a>
		</div>
		// Projects grid
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
			// Existing project card (mock)
			<a
				href={ templ.SafeURL("/"+slug+"/projects/default") }
				class="border border-zinc-200 dark:border-atom-border p-5 flex flex-col gap-4 hover:bg-zinc-50 dark:hover:bg-atom-surface transition-colors"
			>
				<div class="flex items-center gap-2">
					<i data-lucide="folder" width="14" height="14" class="text-zinc-400 dark:text-atom-muted shrink-0"></i>
					<span class="text-sm font-bold text-zinc-900 dark:text-white truncate">{ slug }</span>
				</div>
				<span class="text-[10px] font-mono text-zinc-400 dark:text-atom-muted px-2 py-0.5 border border-zinc-200 dark:border-atom-border self-start">No active services</span>
			</a>
			// Create new project
			<a
				href={ templ.SafeURL("/"+slug+"/new") }
				class="border border-dashed border-zinc-300 dark:border-atom-border p-5 flex items-center justify-center gap-2 text-zinc-400 dark:text-atom-muted hover:text-zinc-600 dark:hover:text-atom-fg hover:border-zinc-400 dark:hover:border-atom-fg hover:bg-zinc-50 dark:hover:bg-atom-surface transition-colors"
			>
				<i data-lucide="plus" width="14" height="14"></i>
				<span class="text-xs font-bold uppercase tracking-widest">New Project</span>
			</a>
		</div>
	</div>
}

