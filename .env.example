# ===========================================================================
# CORE API (platform-server) — LoadServer()
# ===========================================================================
PLATFORM_PORT=8080
PLATFORM_DEBUG=false
PLATFORM_DATABASE_URL=postgres://platform:password@localhost:5432/platform_db?sslmode=disable
PLATFORM_INTERNAL_SECRET=change-me-shared-secret

# ===========================================================================
# WEB BFF (platform-web) — LoadWeb()
# ===========================================================================
PLATFORM_WEB_PORT=3000
PLATFORM_API_URL=http://localhost:8080
PLATFORM_WEB_BASE_URL=http://localhost:3000
# PLATFORM_INTERNAL_SECRET — same value as above, shared between BFF and Core API

# ===========================================================================
# WORKOS (shared by Core API and Web BFF)
# ===========================================================================
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_WEB_REDIRECT_URI=http://localhost:3000/auth/callback

# ===========================================================================
# LOCAL POSTGRES (Docker Compose)
# ===========================================================================
POSTGRES_USER=platform
POSTGRES_PASSWORD=password
POSTGRES_DB=platform_db

# ===========================================================================
# INFRASTRUCTURE — HETZNER
# ===========================================================================
HCLOUD_TOKEN=
HETZNER_SSH_KEY_NAME=

# ===========================================================================
# INFRASTRUCTURE — DIGITALOCEAN
# ===========================================================================
DOCLOUD_TOKEN=
DIGITALOCEAN_SSH_KEY_NAME=

# ===========================================================================
# INFRASTRUCTURE — TAILSCALE
# ===========================================================================
TAILSCALE_OAUTH_CLIENT_ID=
TAILSCALE_OAUTH_CLIENT_SECRET=
TAILSCALE_AUTH_NAT_KEY=tskey-auth-
TAILSCALE_AUTH_K3S_SERVER_KEY=tskey-auth-
TAILSCALE_AUTH_K3S_AGENT_KEY=tskey-auth-

# ===========================================================================
# INFRASTRUCTURE — CLOUDFLARE
# ===========================================================================
CLOUDFLARE_API_TOKEN=
CUSTOM_DOMAIN=example.com

# ===========================================================================
# INFRASTRUCTURE — GCP (TF state backend + RustFS backup target)
# ===========================================================================
GCP_PROJECT_ID=

# ===========================================================================
# INFRASTRUCTURE — MISC
# ===========================================================================
LETS_ENCRYPT_EMAIL=example@email.com
GITHUB_REPO=https://github.com/username/project.git

# ===========================================================================
# CONTAINER REGISTRY
# ===========================================================================
REGISTRY_HOST=
REGISTRY_HTPASSWD=
